# F1 Guesser Duel runtime config
# Copiază valorile în variabilele mediului de deploy.
# Aplicația nu citește automat .env fără un loader extern.

NODE_ENV=production

# Local only. Pe Render nu seta manual PORT; platforma îl injectează automat.
# PORT=3000

# Pe Render Free folosește /tmp pentru date efemere și marchează explicit demo mode.
# Pentru persistent disk plătit schimbă PERSISTENCE_MODE=persistent și mută datele în /var/data.
PERSISTENCE_MODE=ephemeral
DATA_DIR=/tmp/f1guesserduel
# DB_FILE_PATH=/tmp/f1guesserduel/f1guesser.sqlite
ROOMS_FILE_PATH=/tmp/f1guesserduel/rooms.json
ROOM_SAVE_DEBOUNCE_MS=250 # 0-60000

# Obligatoriu în production. Folosește valori lungi și random.
SESSION_SECRET=change-me-to-a-long-random-secret
SOCKET_AUTH_SECRET=change-me-to-another-long-random-secret

# Cookie/session
SESSION_COOKIE_NAME=f1_session
SESSION_MAX_AGE_DAYS=7 # 1-3650
SOCKET_AUTH_TOKEN_MAX_AGE_MS=120000 # 1000-86400000
SESSION_CLEANUP_INTERVAL_MS=900000 # 0-86400000; 0 dezactivează cleanup-ul periodic
COOKIE_SECURE=true
COOKIE_SAMESITE=lax # lax, strict sau none; none cere COOKIE_SECURE=true

# Render rulează aplicația în spatele unui proxy/load balancer.
TRUST_PROXY=true


# Origin-ul public al aplicației. Înlocuiește cu URL-ul tău real de Render.
# Folosit pentru a bloca conexiunile Socket.IO venite din alte site-uri.
PUBLIC_ORIGIN=https://f1guesserduel.onrender.com
# Opțional: origini suplimentare, separate prin virgulă, de exemplu un preview/staging.
# SOCKET_ALLOWED_ORIGINS=https://preview.example.com,http://localhost:3000
