# F1 Guesser Duel runtime config
# Copiază valorile în variabilele mediului de deploy. Aplicația nu citește automat .env fără un loader extern.

NODE_ENV=production
PORT=3000
DATA_DIR=./data

# Obligatoriu în production. Folosește valori lungi și random.
SESSION_SECRET=change-me-to-a-long-random-secret
SOCKET_AUTH_SECRET=change-me-to-another-long-random-secret

# Cookie/session
SESSION_COOKIE_NAME=f1_session
SESSION_MAX_AGE_DAYS=7
SOCKET_AUTH_TOKEN_MAX_AGE_MS=120000
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Setează true dacă rulezi în spatele unui proxy/load balancer care trimite X-Forwarded-*.
TRUST_PROXY=false
