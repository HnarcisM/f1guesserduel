# F1 Guesser Duel runtime config
# Copiază valorile în variabilele mediului de deploy.
# Aplicația nu citește automat .env fără un loader extern.

NODE_ENV=production

# Local only. Pe Render nu seta manual PORT; platforma îl injectează automat.
# PORT=3000

# Pe Render Free conturile pot fi păstrate gratuit cu Postgres extern, de exemplu Neon.
# Camerele active rămân efemere în rooms.json; este ok să dispară la restart/redeploy/sleep.
PERSISTENCE_MODE=ephemeral
DATA_DIR=/tmp/f1guesserduel
ROOMS_FILE_PATH=/tmp/f1guesserduel/rooms.json
ROOM_SAVE_DEBOUNCE_MS=250 # 0-60000
ROOM_CLEANUP_INTERVAL_MS=60000 # 0-86400000; 0 dezactivează cleanup-ul camerelor
ROOM_INACTIVE_TTL_MS=1800000 # 30 minute; minimum 120000

# Redis opțional: dacă REDIS_URL există, fiecare cameră este salvată într-o cheie Redis separată,
# iar rate limiting-ul Socket.IO și auth devine distribuit între procese. Fără REDIS_URL,
# aplicația folosește în continuare rooms.json + contoare în memoria procesului.
# REDIS_URL=rediss://default:password@host:port
# REDIS_KEY_PREFIX=f1guesserduel
# REDIS_CONNECT_TIMEOUT_MS=10000
# REDIS_ROOM_TTL_SECONDS=86400

# Database
# Local/development implicit: sqlite. Pentru conturi persistente pe Render Free setează postgres + DATABASE_URL.
DATABASE_PROVIDER=postgres # sqlite sau postgres
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
POSTGRES_SSL=true
# Opțional: valorile implicite sunt potrivite pentru un singur serviciu Render Free + Neon.
# POSTGRES_POOL_MAX=5
# POSTGRES_CONNECTION_TIMEOUT_MS=15000
# POSTGRES_IDLE_TIMEOUT_MS=30000
# POSTGRES_QUERY_TIMEOUT_MS=20000
# POSTGRES_INIT_RETRY_ATTEMPTS=3
# POSTGRES_INIT_RETRY_BASE_DELAY_MS=1000
# POSTGRES_KEEP_ALIVE_INITIAL_DELAY_MS=10000
# POSTGRES_MAX_LIFETIME_SECONDS=300
# POSTGRES_MIGRATIONS_DIR=server/db/migrations/postgres
# SQLite fallback/local:
# DB_FILE_PATH=/tmp/f1guesserduel/f1guesser.sqlite

# Obligatoriu în production. Folosește valori lungi și random.
SESSION_SECRET=change-me-to-a-long-random-secret
SOCKET_AUTH_SECRET=change-me-to-another-long-random-secret

# Cookie/session
SESSION_COOKIE_NAME=f1_session
SESSION_MAX_AGE_DAYS=7 # 1-3650
SOCKET_AUTH_TOKEN_MAX_AGE_MS=120000 # 1000-86400000
SESSION_CLEANUP_INTERVAL_MS=900000 # 0-86400000; 0 dezactivează cleanup-ul periodic
COOKIE_SECURE=true
COOKIE_SAMESITE=lax # lax, strict sau none; none cere COOKIE_SECURE=true

# Render rulează aplicația în spatele unui proxy/load balancer.
TRUST_PROXY=true

# Origin-ul public al aplicației. Înlocuiește cu URL-ul tău real de Render.
# Folosit pentru a bloca conexiunile Socket.IO venite din alte site-uri.
PUBLIC_ORIGIN=https://f1guesserduel.onrender.com
# Opțional: origini suplimentare, separate prin virgulă, de exemplu un preview/staging.
# SOCKET_ALLOWED_ORIGINS=https://preview.example.com,http://localhost:3000

# Protecție anti-spam pentru event-urile Socket.IO.
SOCKET_RATE_LIMIT_ENABLED=true
SOCKET_RATE_LIMIT_WINDOW_MS=60000 # 1000-3600000

# Logging production. În production recomandat: LOG_LEVEL=info și REQUEST_LOGGING_ENABLED=true.
# Nu se loghează body-uri de request, parole, token-uri, cookie-uri sau secrete.
LOG_LEVEL=info # silent, error, warn, info, debug
REQUEST_LOGGING_ENABLED=true
