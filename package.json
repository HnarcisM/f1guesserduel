{
  "name": "F1GuesserDuel",
  "version": "1.0.0",
  "main": "server/index.js",
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "express": "^4.19.2",
    "helmet": "^8.2.0",
    "pg": "^8.22.0",
    "redis": "^6.1.0",
    "socket.io": "^4.7.5"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "build": "npm run build:css && npm run build:js && npm run build:version",
    "build:css": "node scripts/build-css-bundle.js",
    "build:js": "node scripts/build-js-bundle.js",
    "build:version": "node scripts/version-frontend-assets.js",
    "optimize:raster": "node scripts/optimize-raster-assets.js",
    "optimize:svg": "node scripts/optimize-svg-assets.js",
    "test": "node --test test/*.test.js",
    "test:e2e": "node --test --test-timeout=60000 test/e2e/*.test.js",
    "pretest:e2e": "node scripts/ensure-playwright-browser.js --strict",
    "test:e2e:install": "node scripts/ensure-playwright-browser.js --strict",
    "test:all": "npm test && npm run test:e2e",
    "e2e:install": "npm run test:e2e:install",
    "release:zip": "npm run build && node scripts/create-release-zip.js",
    "release:zip:with-tests": "npm run build && node scripts/create-release-zip.js --with-tests"
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "svgo": "^4.0.2"
  }
}
